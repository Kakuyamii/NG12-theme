                    <label class="ratings-label padded-right strong em">Ratings:</label>
                <div id="suitabilities69fbaf54d1737">
            <ul class="horzlinks suitability-checkboxes">
                                    
                    <li >
                        <input type="checkbox" class="suitable-e" name="suitabilities[]" id="suitabilities69fbaf54d1737_e" value="e"  checked="checked" >
                        <label for="suitabilities69fbaf54d1737_e">e</label>
                    </li>
                                    
                    <li >
                        <input type="checkbox" class="suitable-t" name="suitabilities[]" id="suitabilities69fbaf54d1737_t" value="t"  checked="checked" >
                        <label for="suitabilities69fbaf54d1737_t">t</label>
                    </li>
                                    
                    <li >
                        <input type="checkbox" class="suitable-m" name="suitabilities[]" id="suitabilities69fbaf54d1737_m" value="m"  checked="checked" >
                        <label for="suitabilities69fbaf54d1737_m">m</label>
                    </li>
                                    
                    <li  data-disabled="" >
                        <input type="checkbox" class="suitable-a" name="suitabilities[]" id="suitabilities69fbaf54d1737_a" value="a"  disabled>
                        <label for="suitabilities69fbaf54d1737_a">a</label>
                    </li>
                
            </ul>
            <input type="hidden" name="userkey" value="f3ea6%O5d5d1e8f656f%24cfO9746679aae%P9c1aar71%%767704%7%1%10f%1b5fs989187a3Ob427re77crs%20f32d%%sb%0%1a5d65d20f3r9P167b%69rPf8c4028r06e06eab28e914d426938429b15f15665%s%4d7P%%O%rr7089-3495592" />                            <input type="hidden" name="_token" value="0IOXnoIJ1F2iX0wtL302V8VA7DjoBYPTFAbdWRsC" autocomplete="off">                    </div>
    </div>

    <script>
        /* jshint ignore: start*/
        PHP.set('fire_signup_for_disabled', true);
        // PHP.set('suitabilities_endpoint', "\/suitabilities");
        PHP.set('suitabilities_endpoint', "https:\/\/www.newgrounds.com\/suitabilities");
        PHP.set('suitabilities_opts_disable_on_click', true);
        PHP.set('suitabilities_opts_refresh_page', true);
        /* jshint ignore: end*/

        (function($) {
            var inputs = $('#suitabilities69fbaf54d1737 input');
            var bo = new ngutils.blackout({
                remove_on_click_outside: false,
                remove_on_hide: true
            });

            let engageOrDisengage = (on) => {
                if (on) {
                    bo.show();
                    inputs.disable();
                } else {
                    bo.hide();
                    inputs.enable();
                }
            };

            let checkAtLeastOne = () => {
                if (!inputs.filter(':checked').length) {
                    inputs.first().prop('checked', true);
                }
            };

            $('#suitabilities69fbaf54d1737 li[data-disabled]').click(function() {
                PassportHandler.open(true);
                return false;
            });

            inputs.click(function() {
                checkAtLeastOne();

                let update = inputs.serializeArray();
                let disable_on_click = PHP.get('suitabilities_opts_disable_on_click');

                if (disable_on_click) {
                    engageOrDisengage(true);
                }

                $.postXD(PHP.get('suitabilities_endpoint'), update, () => {
                    let suitability = $.map(update, function(v, k) {
                        return v.value;
                    });

                    ngutils.event.dispatch('suitabilities-updated', suitability);

                    if (PHP.get('suitabilities_opts_refresh_page')) {
                        window.location.href = window.location.href;
                    }
                }).fail(() => {
                    if (disable_on_click) {
                        engageOrDisengage(false);
                    }
                });
            });

        })(jQuery);
    </script>
</div>
                </div>
            </div>
        </div>
    </div>

