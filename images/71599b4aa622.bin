<script>
    PHP.set('min_date', '2009-08-28');
    PHP.set('max_date', '2026-05-06');
</script>
<script>
    // no auto-completion (the false param here)
    (function($) {
        var blackout = new ngutils.blackout();
        var is_mobile = PHP.get('ismobile');

        blackout._onfail = function() {
            blackout.hide();
        };

        var getForm = function() {
            return $('#hub form');
        };

        var intermediary = function(url, obj, nopush) {
            blackout.load(url, function(response) {
                if (!(response && response.content && response.content.length)) {
                    return;
                }

                $('#hub').replaceWith(response.content);
                if (false !== nopush) {
                    history.pushState({}, response.title, url);
                    if (null !== response.title) {
                        document.title = response.title;
                    } else {
                        document.title = 'Search';
                    }
                }

                blackout.hide();
                init();

                if (is_mobile) {
                    toggleMobileFilters($(document).data('hub-filters-visible'));
                }
            });
        };

        window.onpopstate = function(event) {
            intermediary(window.location.href, null, false);
        };

        var initSelects = function() {
            var $form = getForm();
            $('select', $form).off().on('change', function() {
                var submit = this.name !== 'interval';

                submit = submit || this.name === 'interval' && this.value.length;

                if (submit) {
                    $('#after-or-before').hide();

                    if (this.name === 'interval') {
                        // clear out custom values
                        $('#after-or-before input').val('');
                    }

                    $form.submit();
                } else if (this.name === 'interval') {
                    $('#after-or-before').show();
                }
            });
        };

        var initAfterBefore = function() {
            var date_format = 'yy-mm-dd';
            var params = {
                'changeYear': true,
                'dateFormat': date_format,
                'minDate': PHP.get('min_date'),
                'maxDate': PHP.get('max_date'),
                onSelect: function() {
                    getForm().submit();
                }
            };

            $('#after-or-before input[name="after"]').datepicker($.extend(params, {
                //
            }));
            $('#after-or-before input[name="before"]').datepicker($.extend(params, {
                //
            }));
        };

        var mf_labels = {
            "on": "Filters",
            "off": "Hide Filters"
        };

        var toggleMobileFilters = function(show) {
            var $div = $('#hub-filters');
            if (typeof show !== 'boolean') {
                show = !$div.is(':visible');
            }

            if (!show) {
                $div.show().slideToggle(250);;
                //$('#hub-filters-btn').html(mf_labels.on);
                // reset
                $(document).data('hub-filters-visible', false);
            } else {
                $div.hide().slideToggle(250);
                //$('#hub-filters-btn').html(mf_labels.off);
                $(document).data('hub-filters-visible', true);
            }

            return false;
        };

        var initMobileFilters = function() {
            $('#hub-filters-btn').off().click(toggleMobileFilters);
        };

        var stripAddParam = function(name, value) {
            $('nav a, .searchform-sort a, .pagenav a', getForm()).each(function() {
                $(this).replaceUrlParameterByName(name, value);
            });
        };

        var init = function(no_reinit) {
            reinit = false !== no_reinit;

            if (is_mobile) {
                initMobileFilters();
            }

            initSelects();
            initAfterBefore();

            var $form = getForm();

            $form.off('submit').on('submit', function() {

                // suitabilities are handled separately
                const params = $.map($form.serializeArray(), function(param, k) {
                    if (param.name.indexOf('suitabilities[]') !== 0 && param.value.length) {
                        return param;
                    }
                }).filter(param => !['_token', 'userkey'].includes(param.name));

                const url = getForm().attr('action') + '?' + $.param(params);

                intermediary(url);
                return false;

            });

        };

        init(false);

    })(jQuery);
</script>
