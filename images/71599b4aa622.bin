                    </li>
                                    
                    <li >
                        <input type="checkbox" class="suitable-m" name="suitabilities[]" id="suitabilities69fbaeaecc803_m" value="m"  checked="checked" >
                        <label for="suitabilities69fbaeaecc803_m">m</label>
                    </li>
                                    
                    <li  data-disabled="" >
                        <input type="checkbox" class="suitable-a" name="suitabilities[]" id="suitabilities69fbaeaecc803_a" value="a"  disabled>
                        <label for="suitabilities69fbaeaecc803_a">a</label>
                    </li>
                
            </ul>
            <input type="hidden" name="userkey" value="b53a6%Obd5d3a8fb949%14cfO9746679cbe%P9c127r7b%%767704%7%9%10f%185fsa891876eOb039re77frs%dfa323%%se%4%145d65d23f7r0P1080%63rPf8cb058r06e06eab28e914d426938429b15f15665%s%4d7P%%O%rr6580-3457287" />                            <input type="hidden" name="_token" value="R2On7uRV80qv0gIWh5nIlanLt22t8jRakpQEoMoT" autocomplete="off">                    </div>
    </div>

    <script>
        /* jshint ignore: start*/
        PHP.set('fire_signup_for_disabled', true);
        // PHP.set('suitabilities_endpoint', "\/suitabilities");
        PHP.set('suitabilities_endpoint', "https:\/\/www.newgrounds.com\/suitabilities");
        PHP.set('suitabilities_opts_disable_on_click', true);
        PHP.set('suitabilities_opts_refresh_page', true);
        /* jshint ignore: end*/

        (function($) {
            var inputs = $('#suitabilities69fbaeaecc803 input');
            var bo = new ngutils.blackout({
                remove_on_click_outside: false,
                remove_on_hide: true
            });

            let engageOrDisengage = (on) => {
                if (on) {
                    bo.show();
                    inputs.disable();
                } else {
                    bo.hide();
                    inputs.enable();
                }
            };

            let checkAtLeastOne = () => {
                if (!inputs.filter(':checked').length) {
                    inputs.first().prop('checked', true);
                }
            };

            $('#suitabilities69fbaeaecc803 li[data-disabled]').click(function() {
                PassportHandler.open(true);
                return false;
            });

            inputs.click(function() {
                checkAtLeastOne();

                let update = inputs.serializeArray();
                let disable_on_click = PHP.get('suitabilities_opts_disable_on_click');

                if (disable_on_click) {
                    engageOrDisengage(true);
                }

                $.postXD(PHP.get('suitabilities_endpoint'), update, () => {
                    let suitability = $.map(update, function(v, k) {
                        return v.value;
                    });

                    ngutils.event.dispatch('suitabilities-updated', suitability);

                    if (PHP.get('suitabilities_opts_refresh_page')) {
                        window.location.href = window.location.href;
                    }
                }).fail(() => {
                    if (disable_on_click) {
                        engageOrDisengage(false);
                    }
                });
            });

        })(jQuery);
    </script>
</div>
                </div>

