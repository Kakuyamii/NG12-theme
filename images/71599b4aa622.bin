	<div id="load-more-items" data-playlist-func="load-more">
		<p id="is-loading" style="display:none"><em class="fa fa-spin fa-spinner"></em> Loading More...</p>
		<p id="not-loading"><a href="https://www.newgrounds.com/art/featured?offset=28&amp;inner=1">Load More</a></p>
		<script>
			/* jshint esversion: 6 */
			(($) => {
				var $element = $('#load-more-items');

				var registerIds = function($element) {
					return $.map($('[data-hub-id]', $element), function(el, k) {
						return $(el).attr('data-hub-id');
					});
				};

				var ids = registerIds($('div[id^="content-results-"]'));

				var doLoad = (e) => {
					$('#is-loading', $element).show();
					$('#not-loading', $element).hide();

					$.get('https://www.newgrounds.com/art/featured?offset=28&inner=1', (result) => {
						var $content = $(result.content);

						$content = $.map($content, function(el, k) {
							var _id = $(el).attr('data-hub-id');

							if (undefined === _id) {
								return el;
							}

							if (-1 === $.inArray(_id, ids)) {
								ids.push(_id);
								return el;
							}
						});

						// keep a small cache of previously loaded ids
						if (ids.length > 240) {
							ids.slice(240);
						}

						$element.replaceWith($content);
					}, 'json');
					return false;
				};

				$('#not-loading', $element).click(doLoad);

				ngutils.element.whenOnscreen($element, doLoad, 200);

							})(jQuery);
		</script>
	</div>
