            <input type="hidden" name="userkey" value="762a6%Odd5d678f9968%14cfO974367964e%P9c143r76%%767704%7%5%10f%2e5fsb89b879fOb2f0re77frs%32c327%%se%6%1e5d65d22fcr3P1594%62rPf8cb028r06e06eab28e914d426938429b15f15665%s%4d7P%%O%rr7787-3487263" />                            <input type="hidden" name="_token" value="JbwbKltl0Z4QBKmoWj5HrBYD3qMA4eXbq7ZMIaRq" autocomplete="off">                    </div>
    </div>

    <script>
        /* jshint ignore: start*/
        PHP.set('fire_signup_for_disabled', true);
        // PHP.set('suitabilities_endpoint', "\/suitabilities");
        PHP.set('suitabilities_endpoint', "https:\/\/www.newgrounds.com\/suitabilities");
        PHP.set('suitabilities_opts_disable_on_click', true);
        PHP.set('suitabilities_opts_refresh_page', true);
        /* jshint ignore: end*/

        (function($) {
            var inputs = $('#suitabilities69fbad1699b72 input');
            var bo = new ngutils.blackout({
                remove_on_click_outside: false,
                remove_on_hide: true
            });

            let engageOrDisengage = (on) => {
                if (on) {
                    bo.show();
                    inputs.disable();
                } else {
                    bo.hide();
                    inputs.enable();
                }
            };

            let checkAtLeastOne = () => {
                if (!inputs.filter(':checked').length) {
                    inputs.first().prop('checked', true);
                }
            };

            $('#suitabilities69fbad1699b72 li[data-disabled]').click(function() {
                PassportHandler.open(true);
                return false;
            });

            inputs.click(function() {
                checkAtLeastOne();

                let update = inputs.serializeArray();
                let disable_on_click = PHP.get('suitabilities_opts_disable_on_click');

                if (disable_on_click) {
                    engageOrDisengage(true);
                }

                $.postXD(PHP.get('suitabilities_endpoint'), update, () => {
                    let suitability = $.map(update, function(v, k) {
                        return v.value;
                    });

                    ngutils.event.dispatch('suitabilities-updated', suitability);

                    if (PHP.get('suitabilities_opts_refresh_page')) {
                        window.location.href = window.location.href;
                    }
                }).fail(() => {
                    if (disable_on_click) {
                        engageOrDisengage(false);
                    }
                });
            });

        })(jQuery);
    </script>
</div>
